# Local dev: leave VITE_API_URL unset — requests go to /api and Vite proxies to FastAPI.
# If your API is not on 127.0.0.1:8000, set:
# VITE_PROXY_TARGET=http://127.0.0.1:8000

# Ngrok / deployed backend: set full base URL (no trailing slash). Use when building or when dev should hit a tunnel:
# VITE_API_URL=https://your-backend.ngrok-free.app
